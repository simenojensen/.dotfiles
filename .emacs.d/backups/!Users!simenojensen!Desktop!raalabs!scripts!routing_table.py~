def pinger( job_q, results_q ):
    DEVNULL = open(os.devnull,'w')
    while True:
        ip = job_q.get()
        if ip is None: break

        try:
            subprocess.check_call(['ping','-c 3',ip], stdout=DEVNULL)
            results_q.put(ip)
        except:
            pass

def Stats(job_ip, job_reply ):

    p = subprocess.check_output(["ping", "-c", "4", ip])

    output = p.decode("utf-8")
    lines = output.split('\n')
    job_reply.put(lines)



def processStats(pingReply):
    parser = pingparsing.PingParsing()
    stats = parser.parse(dedent(pingReply))

    return stats.as_dict()


def updateVPNStatus(ip_list):
    """Update the VPN connectivity status in the "Operational Status"
    in the "Fleet EDGE Implementation" base. Set ['YES'] or ['NO']
    depending on ips in ip_list
    """

    airtable = Airtable('app7JMgXAkyijlSyd', 'Operational Status', api_key=os.environ['AIRTABLE_API_KEY'])
    records = airtable.get_all(maxRecords=50)
    df = pd.DataFrame.from_records((r['fields'] for r in records))
    df.VPN.dropna(inplace=True)

    for vpn in df.VPN.values:
        if vpn in ip_list:
            airtable.update_by_field('VPN', vpn, {'VPN connected': ['YES']})
        else:
            airtable.update_by_field('VPN', vpn, {'VPN connected': ['NO']})


